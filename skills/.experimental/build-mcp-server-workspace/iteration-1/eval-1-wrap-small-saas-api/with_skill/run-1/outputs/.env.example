# Copy to .env and fill in your values.
# Never commit .env to version control.

# Base URL of your internal issue tracker API (no trailing slash)
ISSUE_TRACKER_BASE_URL=https://your-tracker.internal/api/v1

# API key for authenticating with the issue tracker
ISSUE_TRACKER_API_KEY=your_api_key_here

# Port for the MCP server to listen on (default: 3000)
PORT=3000

# Comma-separated list of allowed Origin headers (for CORS / DNS rebinding protection).
# Leave empty to allow only localhost. Add your deployed frontend origin if needed.
# Example: ALLOWED_ORIGINS=https://claude.ai,https://your-internal-dashboard.internal
ALLOWED_ORIGINS=
