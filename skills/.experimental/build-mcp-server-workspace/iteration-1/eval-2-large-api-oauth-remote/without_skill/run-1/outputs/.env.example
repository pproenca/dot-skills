# Salesforce Connected App credentials
# Create at: Setup > App Manager > New Connected App
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret

# Must match the callback URL registered in your Connected App
SF_REDIRECT_URI=https://your-mcp-server.com/oauth/callback

# Salesforce API version to use
SF_API_VERSION=62.0

# Default login URL (use https://test.salesforce.com for sandbox-only deployments)
SF_LOGIN_URL=https://login.salesforce.com

# Token encryption key: generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# Redis URL for token storage
REDIS_URL=redis://localhost:6379

# Server port
PORT=3000

# Session TTL in seconds (default: 24 hours)
SESSION_TTL=86400
